# Claude API
ANTHROPIC_API_KEY=sk-ant-xxx

# YouTube OAuth2
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Azure TTS
AZURE_TTS_KEY=
AZURE_TTS_REGION=eastus

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database
DB_PATH=data/content-factory.db

# Pipeline
PIPELINE_CRON=0 6 * * *
MAX_DAILY_RUNS=3
COST_BUDGET_DAILY_USD=5.00

# Queue
QUEUE_DATA_DIR=queue/data
QUEUE_DEAD_LETTER_DIR=queue/dead-letter
RUN_RETENTION_DAYS=30
